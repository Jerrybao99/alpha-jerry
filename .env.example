# alpha-jerry 配置样板
# 复制为 .env 并填入真实值；.env 不入库（NFR-08）

# ===== LLM（DeepSeek，BRD C-04）=====
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ===== 数据源（Tushare，BRD C-05）=====
# 从 https://tushare.pro 注册后获取 token，填入下方
# vip 接口（income_vip/balancesheet_vip/cashflow_vip/fina_indicator_vip/forecast_vip/express_vip/fina_mainbz_vip）需 5000 积分
# 积分获取：https://tushare.pro/document/1?doc_id=13 ；积分频次对应表：https://tushare.pro/document/1?doc_id=290
TUSHARE_TOKEN=

# ===== 数据与采集 =====
DATA_DIR=data
CONCURRENCY=4
# 5000积分=500次/分钟（常规数据无上限）；2000积分=200次/分钟（10万次/天）
TUSHARE_RATE_LIMIT=500

# ===== 定时任务（dev-guide §10.2）=====
HOTSPOT_CRON_09=0 9 * * *
HOTSPOT_CRON_17=0 17 * * *
PORTFOLIO_CRON_09=0 9 * * *
PORTFOLIO_CRON_17=0 17 * * *

# ===== 推送 =====
SMTP_HOST=
SMTP_PORT=0
SMTP_USER=
SMTP_PASS=
WECHAT_PUSH_ENABLED=false

# ===== 兜底 =====
LLM_LOCAL_FALLBACK=false
