# alpha-jerry 配置样板
# 复制为 .env 并填入真实值；.env 不入库（NFR-08）

# ===== LLM（DeepSeek，BRD C-04）=====
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ===== 数据源（Tushare，BRD C-05）=====
TUSHARE_TOKEN=

# ===== 数据与采集 =====
DATA_DIR=data
CONCURRENCY=4
TUSHARE_RATE_LIMIT=200

# ===== 定时任务（dev-guide §10.2）=====
HOTSPOT_CRON_09=0 9 * * *
HOTSPOT_CRON_17=0 17 * * *
PORTFOLIO_CRON_09=0 9 * * *
PORTFOLIO_CRON_17=0 17 * * *

# ===== 推送 =====
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
WECHAT_PUSH_ENABLED=false

# ===== 兜底 =====
LLM_LOCAL_FALLBACK=false
